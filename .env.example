# Copy to .env and fill in your values.
# docker compose reads this file automatically.

# Azure subscription (Victros production)
AZURE_SUBSCRIPTION_ID=

# Azure OpenAI credentials (required for LLM features)
VICTROS_AI_ENDPOINT=
VICTROS_AI_KEY=

# Storage backend: "file" (default, no Docker) or "cosmos"
# When running via docker compose, cosmos is set automatically.
# STORAGE_BACKEND=file

# Cosmos DB connection string.
# When running via docker compose, this is set automatically to the emulator.
# For production, set this to your real Azure Cosmos DB connection string.
# COSMOS_CONNECTION_STRING=

# CORS: comma-separated list of origins allowed to call the backend.
# Defaults to localhost dev server when not set.
# In production, set to your SWA URL: https://your-app.azurestaticapps.net
# ALLOWED_ORIGINS=http://localhost:5173

# LLM dev logging — set to "true" to log prompt and completion text (PII risk, dev only)
# LLM_DEV_LOGGING=false
